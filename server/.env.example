# ==========================================
# TICKETERA - Backend Environment Variables
# Copy this file to .env and fill in the values
# ==========================================

# Database (PostgreSQL)
DATABASE_URL=postgres://ticketera_user:ticketera_pass_dev@localhost:5432/ticketera_dev

# Cache (Redis)
REDIS_URL=redis://localhost:6379

# Security - CHANGE IN PRODUCTION!
JWT_SECRET=dev_jwt_secret_change_in_production

# Server
PORT=3000
API_URL=http://localhost:3000

# Frontend URL (for email verification links)
APP_URL=http://localhost:5173

# SMTP Email (leave empty to disable email sending in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="A2 Tickets 360" <your-email@gmail.com>

# Asaas Payment Gateway (leave empty to disable)
ASAAS_API_KEY=your-asaas-api-key
ASAAS_WALLET_ID=your-asaas-wallet-id
ASAAS_ENV=sandbox

# Admin Seed (first admin user created on startup)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
